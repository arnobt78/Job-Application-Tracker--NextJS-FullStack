# ── AI Service ───────────────────────────────────────────
# Shared secret that Next.js sends in X-Internal-Secret header.
# Must match AI_SERVICE_SECRET in Next.js .env.local.
AI_SERVICE_SECRET=change-me-in-production

# CORS — space-separated list of allowed Next.js origins
AI_SERVICE_ALLOWED_ORIGINS=http://localhost:3000

# ── LLM Providers (try in order: Ollama → Groq → OpenRouter → Anthropic) ──
# Ollama — local (no key needed when running at localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Groq — fast cloud inference (free tier available)
GROQ_API_KEY=

# OpenRouter — multi-model gateway
OPENROUTER_API_KEY=

# Anthropic (Claude Haiku 4.5) — final fallback
ANTHROPIC_API_KEY=
