// Jobify Prisma schema
// NextAuth v5 tables added; clerkId renamed to userId throughout.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth v5 / Auth.js required models ────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  /// Bcrypt hash — null for OAuth-only accounts
  password      String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  jobs     Job[]

  @@map("users")
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─── Application models ───────────────────────────────────────────────────────

/// Job application record — scoped per user via userId (NextAuth User.id)
model Job {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  position  String
  company   String
  location  String
  status    String // pending | interview | declined
  mode      String // full-time | part-time | internship

  // URL user applied through — primary key for Bluedoor enrichment join
  applyUrl  String? @map("apply_url")

  // Bluedoor live-posting enrichment fields — all optional, populated by enrich.ts
  bluedoorJobId         String?   @map("bluedoor_job_id")
  bluedoorOrgId         String?   @map("bluedoor_org_id")
  bluedoorProvider      String?   @map("bluedoor_provider") // greenhouse | lever | ashby | workday
  bluedoorStatus        String?   @map("bluedoor_status")   // active | expired | unknown
  bluedoorWorkplaceType String?   @map("bluedoor_workplace_type") // remote | hybrid | on_site
  bluedoorSalaryMin     Float?    @map("bluedoor_salary_min")
  bluedoorSalaryMax     Float?    @map("bluedoor_salary_max")
  bluedoorSalaryCurrency String?  @map("bluedoor_salary_currency")
  bluedoorDescHash      String?   @map("bluedoor_desc_hash")   // SHA-256 of description — detects JD edits
  bluedoorSyncedAt      DateTime? @map("bluedoor_synced_at")   // last successful Bluedoor fetch
  bluedoorChangedAt     DateTime? @map("bluedoor_changed_at")  // when Bluedoor last reported a change
  bluedoorWebhookSubId  String?   @map("bluedoor_webhook_sub_id") // Bluedoor webhook subscription ID for unsubscribe on delete

  // Company/org-level data from Bluedoor /v1/orgs/{org_id} — optional, populated after job match
  companySize      String? @map("company_size")      // e.g. "51-200", "1001-5000"
  companyIndustry  String? @map("company_industry")  // e.g. "Software Development"
  companyHq        String? @map("company_hq")        // e.g. "San Francisco, CA"

  aiInsight    JobAIInsight?
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  // Index for nightly cron: find all jobs with a Bluedoor link across all users
  @@index([bluedoorJobId])
}

/// AI pipeline insight — persisted after the first pipeline run to avoid redundant LLM calls.
/// One-to-one with Job; regenerated on explicit user request.
model JobAIInsight {
  id              String   @id @default(cuid())
  jobId           String   @unique
  userId          String   @map("user_id")
  fitScore        Int?                          // 0–100 fit score from AI
  fitLabel        String?                       // strong_fit | good_fit | partial_fit | poor_fit
  summary         String?                       // 2-3 sentence fit summary
  coverLetter     String?                       // generated cover letter draft
  interviewAngles String[] @default([])         // key talking points / angles for interviews
  redFlags        String[] @default([])         // potential concerns flagged by AI
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Optional user profile — used to personalise AI pipeline with skills + target roles.
/// Created lazily when user saves preferences.
model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  skills          String[] @default([])
  targetRoles     String[] @default([])
  experienceLevel String?                       // entry | mid | senior | staff | principal
  resumeText      String?                       // plain-text resume pasted by user
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
