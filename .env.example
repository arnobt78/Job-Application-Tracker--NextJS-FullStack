# =============================================================================
# Jobify — Environment Variables
# =============================================================================
# Copy to `.env.local` for local dev (Next.js loads .env.local automatically).
# Never commit real secrets. `.env` and `.env.local` are gitignored.
#
# Vercel: Project → Settings → Environment Variables (Production + Preview).
# =============================================================================

# -----------------------------------------------------------------------------
# NextAuth v5 (Auth.js) — REQUIRED
# AUTH_SECRET: Used to sign/encrypt JWT tokens. Generate with:
#   openssl rand -base64 32
# AUTH_GOOGLE_ID/SECRET: Google Cloud Console → OAuth 2.0 credentials
#   Authorized redirect URI: https://your-domain.com/api/auth/callback/google
# AUTH_GITHUB_ID/SECRET: GitHub → Settings → Developer Settings → OAuth Apps
#   Authorization callback URL: https://your-domain.com/api/auth/callback/github
# -----------------------------------------------------------------------------
AUTH_SECRET=your-generated-secret-here
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
AUTH_GITHUB_ID=your_github_oauth_app_client_id
AUTH_GITHUB_SECRET=your_github_oauth_app_client_secret

# -----------------------------------------------------------------------------
# PostgreSQL — Prisma (REQUIRED)
# Used by server actions, SSR prefetch, and migrations.
# -----------------------------------------------------------------------------
# Local example:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/job_tracker_db?schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/job_tracker_db?schema=public"

# Production (e.g. Hetzner VPS, Neon, Supabase):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# DIRECT_URL: same as DATABASE_URL for most self-hosted/VPS Postgres.
# Use a separate direct URL only if your host requires pooled vs direct connections.

# -----------------------------------------------------------------------------
# Upstash Redis (OPTIONAL — recommended for production)
# Enables read-through cache + cross-instance SSE invalidation (Redis Streams).
# Without these, app still works; cache/SSE fall back to in-memory + BroadcastChannel.
# Get credentials: https://console.upstash.com → your database → REST API
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Aliases also supported (legacy / docs naming):
# UPSTASH_REDIS_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_TOKEN=your_upstash_rest_token_here

# -----------------------------------------------------------------------------
# Sentry (OPTIONAL — error tracking; browser tunnel bypasses ad blockers)
# Client events POST to /api/monitoring (same-origin); server sends direct to ingest.
# Get DSN: https://sentry.io → Project Settings → Client Keys (DSN)
# Auth token: Settings → Auth Tokens (source map upload at build time only)
# Vercel: add all four vars to Production + Preview; redeploy after adding.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://key@o4510346504699904.ingest.de.sentry.io/4511546495467600
SENTRY_ORG=arnob-mahmuds-org
SENTRY_PROJECT=job-tracking-app
# Build-only — never expose to browser
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# -----------------------------------------------------------------------------
# Bluedoor Enrichment (OPTIONAL for webhook+cron; API itself is free/keyless)
# BLUEDOOR_WEBHOOK_SECRET: HMAC secret for verifying Bluedoor lifecycle webhooks.
# CRON_SECRET: bearer secret for Vercel cron → /api/cron/enrich authorization.
# -----------------------------------------------------------------------------
BLUEDOOR_WEBHOOK_SECRET=your_hmac_secret_here
CRON_SECRET=your_cron_secret_here

# -----------------------------------------------------------------------------
# Resend — Email Alerts (OPTIONAL)
# Notifies job owner when a tracked posting closes, JD changes, or salary appears.
# App works without it: sendPostingChangeEmail() is a graceful no-op if key absent.
# Get key: https://resend.com → API Keys
# EMAIL_FROM: must be a verified sender domain you own (or use @resend.dev for testing)
# NEXT_PUBLIC_APP_URL: base URL for job deep-links inside alert emails
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Jobify <noreply@yourdomain.com>
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Python AI Service — Phase 2 (OPTIONAL; requires python-ai-service/ running)
# AI_SERVICE_URL: FastAPI base URL (Docker / Coolify / local dev)
# AI_SERVICE_SECRET: shared secret; Next.js sends as X-Internal-Secret header.
#   Must match AI_SERVICE_SECRET in python-ai-service/.env
# Without these: /api/ai/pipeline returns 500; AiInsightsPanel shows error state.
# -----------------------------------------------------------------------------
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# PostHog Analytics (OPTIONAL — product analytics + session replay)
# No-op when NEXT_PUBLIC_POSTHOG_KEY is absent.
# Get key: https://posthog.com → Project Settings → API Keys
# Host: https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# E2E Test Configuration (OPTIONAL — Playwright)
# E2E_SKIP_AUTH=1 enables authenticated test blocks (requires running dev server
# with a pre-seeded NextAuth session cookie).
# BASE_URL overrides the default http://localhost:3000 target.
# -----------------------------------------------------------------------------
# E2E_SKIP_AUTH=1
# BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Node (usually set by Vercel automatically — do not override unless needed)
# -----------------------------------------------------------------------------
# NODE_ENV=production
